<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
	version="3.0">

	<persistence-unit name="Student-Array-Project">

		<provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

	<!--	<class>java_dev.java_advance.framework.hibernate_jpa.onetoone.entity.Project</class>
		<class>java_dev.java_advance.framework.hibernate_jpa.onetoone.entity.Student</class> -->
		
		<class>java_dev.java_advance.framework.hibernate_jpa.onetomany_finite.entity.Project1</class>
		<class>java_dev.java_advance.framework.hibernate_jpa.onetomany_finite.entity.Student1</class>

		<properties>

			<property name="jakarta.persistence.jdbc.driver"
				value="com.mysql.cj.jdbc.Driver" />
			<property name="jakarta.persistence.jdbc.url"
				value="jdbc:mysql://localhost:3306/student-array-project-database" />
			<property name="jakarta.persistence.jdbc.user" value="root" />
			<property name="jakarta.persistence.jdbc.password" value="anant6350" />

			<!-- Correct Dialect -->
			<property name="hibernate.dialect"
				value="org.hibernate.dialect.MySQLDialect" />

			<property name="hibernate.show_sql" value="true" />
			<property name="hibernate.format_sql" value="true" />
			<property name="hibernate.hbm2ddl.auto" value="update" />

		</properties>

	</persistence-unit>

</persistence>